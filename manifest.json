{
  "manifest_version": 3,
  "name": "YouTube Transcript Viewer",
  "version": "1.0",
  "description": "YouTubeの動画ページで字幕・文字起こしをサイドパネルに自動表示",
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [],
  "host_permissions": [
    "https://www.youtube.com/*",
    "https://*.youtube.com/*",
    "https://*.googleapis.com/*",
    "https://*.googlevideo.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "icons": {}
}
